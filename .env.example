# Public (Vite) — committed safe values; do NOT put secrets here.
VITE_SUPABASE_PROJECT_ID=qhbpxctyequhjbeogofi
VITE_SUPABASE_URL=https://qhbpxctyequhjbeogofi.supabase.co
# Supabase publishable key (sb_publishable_… or the legacy anon JWT). Public.
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# -----------------------------------------------------------------
# Supabase Edge Function secrets — set via the Supabase dashboard or
# `supabase secrets set` / `npx supabase secrets set`.
# Do NOT commit real values.
# -----------------------------------------------------------------

# Razorpay (use test keys until production is ready).
# Set with: npx supabase secrets set RAZORPAY_KEY_ID=... RAZORPAY_KEY_SECRET=...
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Razorpay webhook secret — random string you set in the dashboard
# (Settings → Webhooks → Add new). Save the same value here.
RAZORPAY_WEBHOOK_SECRET=replace-with-a-long-random-string

# Resend (transactional email — https://resend.com).
# API key from Resend → API Keys. The sending domain (see FROM_DOMAIN in
# send-transactional-email/index.ts) must be verified in Resend → Domains
# with its DKIM/SPF DNS records in place.
# Set with: npx supabase secrets set RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# Resend webhook signing secret — from Resend → Webhooks → your endpoint →
# Signing Secret. Point the webhook at handle-email-suppression for the
# email.bounced and email.complained events.
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# Where the live site is served from (used in callback URLs and emails).
PUBLIC_SITE_URL=https://xenium-sites.com

# Default amount to charge for a Xenium experience (paise; 75000 = ₹750).
XENIUM_DEFAULT_AMOUNT_PAISE=75000

# Tracking page email-OTP toggle.
# 'true' makes /track require an email OTP before showing order details.
TRACK_REQUIRE_OTP=false
